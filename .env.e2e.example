# E2E test environment — copy to .env.e2e and fill in real values
# .env.e2e is gitignored; never commit real credentials

# Override base URL if the dev server runs on a different port/host
# E2E_BASE_URL=http://localhost:3002

# Real credentials for the "real API" test suite
# The user must exist in the backend and have ADMIN or SUPER_ADMIN role
E2E_TEST_EMAIL=your-test-user@example.com
E2E_TEST_PASSWORD=your-test-password
