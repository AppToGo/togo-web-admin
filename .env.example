# API Configuration
# Base URL of the ToGo API (NestJS backend) — include the /v1 version suffix
NEXT_PUBLIC_API_URL=http://localhost:3000/v1

# WebSocket URL for realtime orders (socket.io) — API base WITHOUT /v1
# If unset, it is derived from NEXT_PUBLIC_API_URL by stripping /v1
NEXT_PUBLIC_WS_URL=http://localhost:3000

# App Configuration
NEXT_PUBLIC_APP_NAME=Togo Admin
NEXT_PUBLIC_APP_VERSION=1.0.0

# Google Maps — map display (Maps JavaScript API must be enabled)
# Restrict this key to HTTP referrers in Google Cloud Console (browser-side only)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional: Map ID for AdvancedMarker styling (Google Cloud Console > Maps > Map Styles)
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Google Maps — server-side geocoding (Geocoding API must be enabled)
# This key is NEVER sent to the browser. Use IP restriction or no restriction in GCP.
# The Geocoding API rejects browser requests made with HTTP-referrer-restricted keys.
GOOGLE_MAPS_GEOCODING_KEY=

# Meta Embedded Signup — onboarding asistido de WhatsApp (Facebook Login for Business)
# App Secret NUNCA va aquí: solo vive en el backend.
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_CONFIG_ID=
NEXT_PUBLIC_META_GRAPH_VERSION=v25.0
